<form action="/upload_file" method="POST" enctype="multipart/form-data" id="<%= id %>" class="<%= show ? '' : 'hidden' %> h-screen p-4 w-screen flex gap-10 max-md:flex-col max-md:items-center">
  <div class="w-2/3 flex max-xl:flex-col gap-20 xl:justify-evenly max-xl:items-center">
    <%- include ('../components/label.ejs', {input_form: 'file_upload_input_' + id, type: 'file'})%>
    <input type="file" id="file_upload_input_<%= id %>" name="file" accept=".csv, .xlsx, .xls" onchange="show_second(this)" />
    <%- include ('../components/label.ejs', {input_form: 'file_upload_input_2_' + id, type: 'hidden'})%>
    <input type="hidden" id="file_upload_input_2_<%= id %>" name="file" accept=".csv, .xlsx, .xls" />
  </div>

  <div class="md:w-1/3 md:border-l-2 border-solid border-imt-dark flex flex-col items-center align-bottom -my-4 py-4">
    <h1><%= name %></h1>
    <div class="grid grid-cols-2 gap-2 ml-5">
      <%- include("../../components/molecules/iri_form_molecule") %>
    </div>
    <div class="flex gap-2 justify-between my-2 w-full pl-4 pr-8">
      <%- include("../../components/atoms/switch_media_percentile") %>
    </div>

    <%- include('../../components/atoms/button', {text: 'Enviar'}) %>
    <p id="error_message" class="text-red-600 hidden">
      Error: Ingresa por lo menos un archivo
    </p>
    <p class="hidden bg-red-600 hover:bg-red-700"></p>
  </div>
</form>