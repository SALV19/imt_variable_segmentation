<form action="/upload_file" method="POST" enctype="multipart/form-data" id="<%= id %>" class="<%= show ? '' : 'hidden' %> h-screen p-4 w-1/3 flex gap-10 max-md:flex-col max-md:items-center">
  <div class="md:border-l-2 border-solid border-imt-dark flex flex-col items-center align-bottom -my-4 py-4">
    <h1><%= name %></h1>
    <div class="grid grid-cols-2 gap-2 ml-5">
      <%- include("../../components/molecules/iri_form_molecule") %>
    </div>
    <div class="flex gap-2 justify-between my-2 w-full pl-4 pr-8">
      <%- include("../../components/atoms/switch_media_percentile") %>
    </div>

    <%- include('../../components/atoms/button', {text: 'Enviar'}) %>
    <p id="error_message" class="text-red-600 hidden text-center">
      Error: Ingresa por lo menos un archivo
    </p>
    <p class="hidden bg-red-600 hover:bg-red-700"></p>
  </div>
</form>