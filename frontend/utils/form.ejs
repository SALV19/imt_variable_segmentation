<link rel="stylesheet" href="/css/form.css">
<form 
	action="/upload_file" 
	method="POST" 
	enctype="multipart/form-data" id="form"
	class="h-screen p-4 w-screen flex gap-10">
			<div class="w-2/3 flex gap-20 justify-evenly">
				<%- include ('../components/label.ejs', {input_form: 'file'})%>
				<input 
					type="file"
					id="file"
					name="file"
					accept=".csv, .xlsx, .xls"
					onchange=show_second()
					>
				<%- include ('../components/label.ejs', {input_form: 'hidden'})%>
				<input 
					type="hidden"
					id="hidden"
					name="file"
					accept=".csv, .xlsx, .xls"
					>
			</div>

			<div class="w-1/3 border-l-2 border-solid border-red-900 flex flex-col items-center align-bottom">
				<div class="grid grid-cols-2 gap-2 ml-5">
					<label >Diferencia para seleccionar puntos singulares</label>
					<input 
						required
						type="number"
						id="singular_points"
						name="singular_points"
						class="mb-5 border-2 border-gray-400 border-solid w-1/2 mx-auto"
						>
					<label >Diferencia para unir segmentos adyacentes</label>
					<input 
						required
						type="number"
						id="join_segments"
						name="join_segments"
						class="mb-5 border-2 border-gray-400 border-solid w-1/2 mx-auto"
						>
						<label >Percentil</label>
					<input 
						required
						type="number"
						id="percentil"
						name="percentil"
						class="mb-5 border-2 border-gray-400 border-solid w-1/2 mx-auto"
						>
					<label >Longitud de la media móvil</label>
					<input 
						required
						type="number"
						id="moving_avg"
						name="moving_avg"
						class="mb-5 border-2 border-gray-400 border-solid w-1/2 mx-auto"
						>
					<label>Metros en que fue medido el parámetro</label>
					<input 
						required
						type="number"
						id="distance"
						name="distance"
						class="mb-5 border-2 border-gray-400 border-solid w-1/2 mx-auto"
						>
				</div>

				<button type="submit" id="submit" class=" tilt-shaking p-2 bg-blue-700 hover:bg-blue-800 text-white font-bold text-xl px-6 rounded-sm">Send</button>
				<p id="error_message" class="text-red-600 hidden">Error: Ingresa por lo menos un archivo</p>
				<p class="hidden bg-red-600 hover:bg-red-700"></p>
			</div>

</form>

<script src="/js/upload_files.js"></script>