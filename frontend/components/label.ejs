<label for=<%= input_form %> class="label_input <%= input_form == 'hidden' ? 'hidden' : ''%>">
	<div class="insert_file flex flex-col">
		<div class="mb-5">
			<%- include ('../icon/csv.ejs')%>
			<%- include ('../icon/xlsx.ejs')%>
		</div>
		<button
			type="button"
			class="text-white bg-blue-700 p-2 rounded-full font-semibold hover:bg-blue-800 mt-5 text-xl"
			onclick="loadFile(this)">
			Cargar archivo
		</button>
		<p class='text-md text-[#777] w-1/3 text-center'>O arrastra un archivo</p>
	</div>
	<div class="load_file hide">
		
	</div>
</label>	