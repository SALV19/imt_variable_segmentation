{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext", 
    "moduleResolution": "NodeNext", 
    "target": "ES2022", 
    "outDir": "./dist-test", 
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true, 
    "skipLibCheck": true,
    "noEmit": false,
    "isolatedModules": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.test.ts" 
  ],
  "exclude": [
    "node_modules",
    "dist" 
  ]
}