{
  "compilerOptions": {
    "target": "es2022", 
    "module": "nodenext", 
    "moduleResolution": "nodenext", 
    "esModuleInterop": true, 
    "forceConsistentCasingInFileNames": true, 
    "strict": true, 
    "skipLibCheck": true, 
    "lib": ["es2022", "dom"], 
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["node", "jest"]
  },
  "include": ["src/**/*.ts"], 
  "exclude": ["node_modules"]
}